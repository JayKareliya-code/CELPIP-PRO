# ─── CELPIP Platform — Staging Environment Template ──────────────────────────
# Copy this file to .env on your staging server and fill in all values.
# Do NOT commit this file with real secrets.
#
# Differences from .env.example:
#   • APP_ENV=staging
#   • Uses Stripe test-mode keys
#   • Uses a staging-specific Clerk application
#   • Uses a staging Sentry DSN
#   • CORS_ORIGINS points at staging domain

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=staging
APP_NAME=CELPIP Platform API (Staging)
DEBUG=false

# ── Network / CORS ────────────────────────────────────────────────────────────
# Set to your staging domain — drives CORS_ORIGINS and FRONTEND_URL automatically.
# Or override CORS_ORIGINS and FRONTEND_URL directly below.
HOST_IP=staging.your-domain.com

# Explicit override (uncomment if HOST_IP auto-compute is insufficient):
# CORS_ORIGINS=["https://staging.your-domain.com"]
# FRONTEND_URL=https://staging.your-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://celpip:<password>@<db-host>:5432/celpip_staging

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://<redis-host>:6379/0

# ── Clerk Auth (staging application) ─────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks

# ── AWS S3 / Cloudflare R2 ────────────────────────────────────────────────────
S3_BUCKET_NAME=celpip-staging
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com  # if using R2

# ── Stripe (test-mode keys) ───────────────────────────────────────────────────
STRIPE_PUBLISH_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_test_REPLACE_ME
STRIPE_ULTRA_PRICE_ID=price_test_REPLACE_ME

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE_ME@oXXX.ingest.sentry.io/YYYY
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
METRICS_AUTH_TOKEN=

# ── Flower ────────────────────────────────────────────────────────────────────
FLOWER_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_FLAGS_JSON={}
