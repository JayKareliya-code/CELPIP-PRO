# ─────────────────────────────────────────────────────────────────────────────
# CELPIP Platform API — Environment Variables
# Copy this file to `.env` and fill in real values before starting the server.
# NEVER commit `.env` to version control — it is in .gitignore.
#
# Quick-start for local dev:
#   1. Copy: cp .env.example .env
#   2. Fill in CLERK_SECRET_KEY, CLERK_PUBLISHABLE_KEY
#   3. Fill in OPENAI_API_KEY (required for Phase 2 AI scoring)
#   4. Fill in AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (required for speaking)
#   5. docker compose up -d  (starts postgres + redis)
#   6. alembic upgrade head
#   7. python scripts/seed_prompts.py
#   8. uvicorn app.main:app --reload
#
# Dev auth bypass: use Authorization: Bearer test_token_<any_id>
#   This bypasses Clerk JWT validation when running locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS='["http://localhost:3000"]'

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://celpip:celpip@localhost:5432/celpip_dev

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Auth (REQUIRED) ─────────────────────────────────────────────────────
# Get these from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Override only for custom Clerk domains:
# CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# ── AWS S3 / Cloudflare R2 (REQUIRED for speaking audio upload) ───────────────
# SPEAKING TASKS WILL FAIL until you add real values here.
S3_BUCKET_NAME=celpip-audio-dev
S3_REGION=ca-central-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
# For Cloudflare R2, uncomment and set:
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# ── AI Scoring — Phase 2 (REQUIRED for scoring pipeline) ─────────────────────
# Provider selection. Only set the key for your chosen provider.
AI_SCORING_PROVIDER=openai        # openai | anthropic | gemini
AI_SCORING_MODEL=gpt-4o-mini
AI_STT_PROVIDER=openai
AI_STT_MODEL=whisper-1
AI_FEEDBACK_PROVIDER=openai
AI_FEEDBACK_MODEL=gpt-4o-mini
AI_MAX_RETRIES=3
AI_TIMEOUT_SECS=90

# OpenAI API key — REQUIRED when AI_SCORING_PROVIDER=openai (default)
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Anthropic key — only needed if AI_SCORING_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Gemini key — only needed if AI_SCORING_PROVIDER=gemini
# GEMINI_API_KEY=REPLACE_ME
