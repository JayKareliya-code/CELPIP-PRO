# ─────────────────────────────────────────────────────────────────────────────
# .env.example — CELPIP PRO API Configuration Template
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=CELPIP Platform API
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# ── Database (PostgreSQL + asyncpg) ─────────────────────────────────────────────
# IMPORTANT: Create the database and user first (see instructions below)
DATABASE_URL=postgresql+asyncpg://celpip:celpip@localhost:5432/celpip_dev

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Flower (Celery monitoring UI) ─────────────────────────────────────────────
# Required in docker-compose; password for the 'admin' user. Rotate before deploy.
FLOWER_PASSWORD=changeme

# ── Clerk Auth (get from https://dashboard.clerk.com/apps) ────────────────────
# REQUIRED — get these from your Clerk dashboard
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks

# ── AWS S3 / Cloudflare R2 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=celpip
S3_REGION=us-east-1
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com  # For R2 only

# ── OpenAI API (optional, for AI scoring) ──────────────────────────────────────
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
