# =============================================================================
# CELPIP PRO - Root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets (NEVER commit these)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.development
*.secret

# ---------------------------------------------------------------------------
# Python / FastAPI (apps/api)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
*.egg
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.log

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# Node.js / Next.js (apps/web)
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js build output
.next/
out/
build/

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Keep docker-compose.yml but ignore local overrides
docker-compose.override.yml

# ---------------------------------------------------------------------------
# IDE & Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Logs & Temp files
# ---------------------------------------------------------------------------
logs/
*.log
tmp/
temp/

# ---------------------------------------------------------------------------
# Alembic — keep migrations, ignore env files auto-generated
# ---------------------------------------------------------------------------
# (migrations themselves SHOULD be committed)
